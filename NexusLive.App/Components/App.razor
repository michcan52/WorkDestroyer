<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    
    <!-- Bootstrap CSS for layout and utilities -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Google Fonts for modern aesthetics -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Custom theme overrides (with cache buster v3) -->
    <link rel="stylesheet" href="css/app.css?v=3" />

    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="@Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer" />
    
    <!-- Blazor framework script -->
    <script src="_framework/blazor.web.js"></script>
    <!-- Bootstrap Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Native Web Speech API Audio Capture Bridge for Real-Time Microphone Input -->
    <script>
        window.speechBridge = {
            recognition: null,
            dotNetRef: null,
            active: false,
            lastResultTime: 0,
            watchdogInterval: null,
            start: function (dotNetRef, lang) {
                this.dotNetRef = dotNetRef;
                this.active = true;
                this.lastResultTime = Date.now();
                
                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                if (!SpeechRecognition) {
                    console.error("Speech recognition is not supported in this browser.");
                    return;
                }
                
                this.recognition = new SpeechRecognition();
                this.recognition.continuous = true;
                this.recognition.interimResults = true; // Use interim results to keep connection active and responsive
                this.recognition.lang = lang || 'es-ES';
                
                // Track sent final indices to prevent duplication in continuous mode
                const sentIndices = new Set();
                
                this.recognition.onresult = (event) => {
                    this.lastResultTime = Date.now(); // Feed watchdog on any speech activity
                    
                    for (let i = event.resultIndex; i < event.results.length; ++i) {
                        if (event.results[i].isFinal) {
                            if (!sentIndices.has(i)) {
                                sentIndices.add(i);
                                const transcript = event.results[i][0].transcript.trim();
                                if (transcript.length > 0) {
                                    console.log("[SPEECH RECOGNITION] Final segment: " + transcript);
                                    if (this.dotNetRef) {
                                        this.dotNetRef.invokeMethodAsync('ReceiveSpeechSegment', transcript);
                                    }
                                }
                            }
                        }
                    }
                };
                
                this.recognition.onerror = (event) => {
                    console.error("[SPEECH RECOGNITION] Error: ", event.error);
                    if (event.error === 'not-allowed' || event.error === 'service-not-allowed') {
                        this.active = false;
                        this.stopWatchdog();
                    }
                };
                
                this.recognition.onend = () => {
                    console.log("[SPEECH RECOGNITION] Session ended.");
                    if (this.active && this.dotNetRef) {
                        setTimeout(() => {
                            try {
                                if (this.active && this.recognition) {
                                    sentIndices.clear();
                                    this.recognition.start();
                                    this.lastResultTime = Date.now();
                                    console.log("[SPEECH RECOGNITION] Restarted session successfully.");
                                }
                            } catch(e) {
                                console.error("[SPEECH RECOGNITION] Restart error: ", e);
                            }
                        }, 250);
                    }
                };
                
                this.startWatchdog();
                
                try {
                    this.recognition.start();
                    console.log("[SPEECH RECOGNITION] Started successfully. Language: " + this.recognition.lang);
                } catch(e) {
                    console.error("[SPEECH RECOGNITION] Start failed: ", e);
                }
            },
            
            startWatchdog: function () {
                this.stopWatchdog();
                this.watchdogInterval = setInterval(() => {
                    if (this.active && this.recognition) {
                        const inactiveTime = Date.now() - this.lastResultTime;
                        if (inactiveTime > 12000) { // 12 seconds of silence or hung state
                            console.log("[SPEECH RECOGNITION WATCHDOG] Refreshing speech connection...");
                            try {
                                this.recognition.stop(); // Triggers onend and auto-restarts safely
                            } catch (e) {
                                console.error("[SPEECH RECOGNITION WATCHDOG] Error: ", e);
                            }
                        }
                    }
                }, 4000);
            },
            
            stopWatchdog: function () {
                if (this.watchdogInterval) {
                    clearInterval(this.watchdogInterval);
                    this.watchdogInterval = null;
                }
            },
            
            stop: function () {
                this.active = false;
                this.stopWatchdog();
                this.dotNetRef = null;
                if (this.recognition) {
                    try {
                        this.recognition.stop();
                    } catch(e) {}
                    console.log("[SPEECH RECOGNITION] Stopped manually.");
                }
            }
        };
    </script>
</body>
</html>
